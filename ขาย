---------------------------------------------------------
-- ระบบการทำงาน (Logic เดิมที่เสถียรอยู่แล้ว)
---------------------------------------------------------
local Points = {}
local IsFarming = false
local FarmTime = 15

TimeInput.FocusLost:Connect(function()
    local val = tonumber(TimeInput.Text)
    if val then FarmTime = val else TimeInput.Text = "15" FarmTime = 15 end
end)

AddBtn.MouseButton1Click:Connect(function()
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        table.insert(Points, hrp.Position)
        Status.Text = "STATUS: SAVED " .. #Points .. " POINTS"
    end
end)

ClearBtn.MouseButton1Click:Connect(function()
    Points = {}
    Status.Text = "STATUS: CLEARED"
end)

StartBtn.MouseButton1Click:Connect(function()
    IsFarming = not IsFarming
    if IsFarming then
        StartBtn.Text = "STOP FARMING"
        StartBtn.BackgroundColor3 = Color3.fromRGB(150, 30, 30)
    else
        StartBtn.Text = "START FARMING"
        StartBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
        Status.Text = "STATUS: IDLE"
    end
end)

local function FastClick()
    local x, y = workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2
    VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
    task.wait(0.05)
    VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if IsFarming and #Points > 0 then
            for i, pos in ipairs(Points) do
                if not IsFarming then break end
                local char = Player.Character
                if char and char:FindFirstChild("Humanoid") then
                    Status.Text = "MOVING TO POINT [" .. i .. "]"
                    char.Humanoid:MoveTo(pos)
                    local t = 0
                    while (char.HumanoidRootPart.Position - pos).Magnitude > 4 and IsFarming and t < 15 do
                        task.wait(0.2) t = t + 0.2
                    end
                    if IsFarming then
                        Status.Text = "WORKING... (" .. FarmTime .. "S)"
                        local start = tick()
                        while tick() - start < FarmTime and IsFarming do
                            VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                            FastClick()
                            task.wait(0.15)
                        end
                        VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                        task.wait(0.5)
                    end
                end
            end
        end
    end
end)
