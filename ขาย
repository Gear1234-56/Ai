-- ฟังก์ชันสร้างปุ่ม (Size สมส่วน ไม่เล็กไป ไม่ใหญ่จนล้น)
local function CreateButton(text, order, color)
    local btn = Instance.new("TextButton", Container)
    btn.Size = UDim2.new(0.88, 0, 0, 40) -- ความสูงกำลังดีสำหรับมือถือและคอม
    btn.Text = text
    btn.BackgroundColor3 = color or Color3.fromRGB(35, 35, 35)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.LayoutOrder = order
    btn.AutoButtonColor = true
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    -- ใส่ Stroke เล็กๆ ให้ปุ่มดูคม
    local s = Instance.new("UIStroke", btn)
    s.Thickness = 1
    s.Transparency = 0.8
    s.Color = Color3.new(1,1,1)
    
    return btn
end

