-- [[ ESP Box (เส้นขอบ) + Health Bar (บนหัว) ]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local function CreateESP(player)
    if player == LocalPlayer then return end

    -- สร้างหลอดเลือด (BillboardGui)
    local function AddHealthBar(char)
        local head = char:WaitForChild("Head", 5)
        if not head then return end
        
        local bgui = Instance.new("BillboardGui")
        bgui.Name = "HealthESP"
        bgui.Adornee = head
        bgui.Size = UDim2.new(4, 0, 0.5, 0)
        bgui.StudsOffset = Vector3.new(0, 2.5, 0) -- ตำแหน่งบนหัว
        bgui.AlwaysOnTop = true
        bgui.Parent = head

        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- พื้นหลังดำ
        frame.BorderSizePixel = 0
        frame.Parent = bgui

        local healthInner = Instance.new("Frame")
        healthInner.Name = "Bar"
        healthInner.Size = UDim2.new(1, 0, 1, 0)
        healthInner.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- สีเขียว
        healthInner.BorderSizePixel = 0
        healthInner.Parent = frame

        -- อัปเดตเลือดตลอดเวลา
        local hum = char:WaitForChild("Humanoid")
        hum.HealthChanged:Connect(function(hp)
            healthInner.Size = UDim2.new(hp / hum.MaxHealth, 0, 1, 0)
            -- เปลี่ยนสีตามเลือด (น้อยลงจะเริ่มแดง)
            healthInner.BackgroundColor3 = Color3.fromHSV((hp / hum.MaxHealth) * 0.3, 1, 1)
        end)
    end

    -- สร้างเส้นขอบ (Highlight แบบล้อมขอบอย่างเดียว)
    local function AddBox(char)
        if char:FindFirstChild("BoxESP") then char.BoxESP:Destroy() end
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "BoxESP"
        highlight.Parent = char
        highlight.Adornee = char
        highlight.FillTransparency = 1 -- [[ ทำให้ไม่มีสีตรงตัวละคร (มีแค่ขอบ) ]]
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- สีขอบขาว
        highlight.OutlineTransparency = 0
    end

    player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        AddBox(char)
        AddHealthBar(char)
    end)

    if player.Character then
        AddBox(player.Character)
        AddHealthBar(player.Character)
    end
end

-- รันระบบ
for _, p in pairs(Players:GetPlayers()) do
    CreateESP(p)
end
Players.PlayerAdded:Connect(CreateESP)

print("ESP Box & Health Bar Active!")
