-- ==========================================
-- ฟังก์ชันสำหรับเพิ่มความโค้งมน (UICorner)
-- ==========================================
local function MakeRounded(instance, cornerRadius)
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0, cornerRadius) -- ตั้งค่าความมน (เป็นพิกเซล)
    uiCorner.Parent = instance
end

