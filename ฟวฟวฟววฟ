local sliding = false
SliderBtn.MouseButton1Down:Connect(function() sliding = true end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)

UserInputService.InputChanged:Connect(function(input)
    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
        local pos = math.clamp((input.Position.X - SliderBtn.AbsolutePosition.X) / SliderBtn.AbsoluteSize.X, 0, 1)
        Settings.FOVSize = math.floor(pos * 500)
        SliderLabel.Text = "FOV Size: " .. Settings.FOVSize
        Fill.Size = UDim2.new(pos, 0, 1, 0)
    end
end)

